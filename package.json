{
  "name": "defi-analytics-backend",
  "version": "1.0.0",
  "description": "DeFi Analytics Backend with blockchain event listeners, PostgreSQL, and real-time updates",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run"
  },
  "keywords": ["defi", "analytics", "blockchain", "web3", "postgresql"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "pg": "^8.11.3",
    "knex": "^3.0.1",
    "ethers": "^6.8.1",
    "redis": "^4.6.10",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "bull": "^4.11.5",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.8",
    "@types/pg": "^8.10.7",
    "@types/cors": "^2.8.15",
    "@types/compression": "^1.7.4",
    "@types/node": "^20.8.10",
    "@types/node-cron": "^3.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "typescript": "^5.2.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "^8.52.0"
  }
